# Local BG3 paths for integration / parity tests.
# Copy this file to .env and update the paths for your system.
# .env is gitignored and will not be committed.

# Directory containing vanilla .lsfx files (extracted from Effects.pak)
BG3_LSFX_DIR=

# Directory containing vanilla .lsefx files (LSEFX files are in the Data folder, 
# under Editor\Mods\GustavX\Assets\Effects)
BG3_LSEFX_DIR=

# BG3 game install path
BG3_GAME_DIR=